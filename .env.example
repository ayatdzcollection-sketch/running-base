# Copy this to .env.local and fill in your Supabase values.
# These are public by design (Supabase's security model is Row Level Security,
# not key secrecy). The anon key is safe to expose in a static site.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
